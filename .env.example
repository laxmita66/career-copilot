# ──────────────────────────────────────────────────────────────────────────────
# Career Copilot — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running the app.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Base URL of the Express/Node.js backend API
# Development:  http://localhost:5000/api
# Production:   https://api.careercopilot.io/api
VITE_API_URL=http://localhost:5000/api

# JWT token storage key (must match what the backend sends)
VITE_TOKEN_KEY=cc_token

# Application name (used in page titles / meta)
VITE_APP_NAME=Career Copilot

# ── AI Service (future) ────────────────────────────────────────────────────────
# If calling AI services directly from the frontend (not recommended for prod),
# add keys here. Prefer proxying through the backend.
# VITE_OPENAI_API_KEY=sk-...
